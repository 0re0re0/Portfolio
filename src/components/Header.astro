---
const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname.slice(1);
---

<nav class="navbar">
  <ul class="nav-links">
    <li>
      <a href="/" class={currentPath === "" ? "active" : ""}>Sobre Mi</a>
    </li>
    <li>
      <a href="/projects" class={currentPath === "projects" ? "active" : ""}
        >Proyectos
      </a>
    </li>
  </ul>
</nav>
